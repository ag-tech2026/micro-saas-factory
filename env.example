# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/db_name

# Authentication - Better Auth
# Generate key using https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=32-char-random-string

# Google OAuth (for social login)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Callback URL: {APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# AI Integration via OpenRouter (Optional - for chat functionality)
# Get your API key from: https://openrouter.ai/settings/keys
# View available models at: https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL="openai/gpt-5-mini"

# Optional - for vector search only
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# App URL (for production deployments)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File storage (optional - if app required file uploads)
BLOB_READ_WRITE_TOKEN=

# Polar payment processing
# Get these from: https://polar.sh/settings/tokens
POLAR_ACCESS_TOKEN=
# Create a product in Polar Dashboard, copy the Product ID (not Price ID)
POLAR_PRODUCT_ID=
# Webhook secret from Polar Dashboard -> Webhooks -> Add endpoint
POLAR_WEBHOOK_SECRET=

# Inngest background jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
